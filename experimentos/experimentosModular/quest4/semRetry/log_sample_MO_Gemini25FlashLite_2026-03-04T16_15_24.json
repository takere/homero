{
    "interpretation": [
        {
            "typeQuestion": "IntegerQuestion",
            "question": "1. Qual a sua idade atual?",
            "options": null
        },
        {
            "typeQuestion": "IntegerQuestion",
            "question": "2. Com que idade voc\u00ea recebeu o diagn\u00f3stico de Diabetes Mellitus Tipo 1?",
            "options": null
        },
        {
            "typeQuestion": "TextQuestion",
            "question": "3. Qual foi o seu \u00faltimo valor de Hemoglobina Glicada (HbA1c)?",
            "options": null
        },
        {
            "typeQuestion": "SingleSelectionQuestion",
            "question": "4. Qual o m\u00e9todo principal que voc\u00ea utiliza para monitorar sua glicose?",
            "options": [
                "Glicos\u00edmetro (ponta de dedo)",
                "Sensor de monitoramento cont\u00ednuo (CGM)",
                "Flash (FreeStyle Libre)"
            ]
        },
        {
            "typeQuestion": "IntegerQuestion",
            "question": "5. Quantas vezes ao dia, em m\u00e9dia, voc\u00ea realiza a ponta de dedo ou verifica o sensor?",
            "options": null
        },
        {
            "typeQuestion": "SingleSelectionQuestion",
            "question": "6. Qual o seu esquema atual de insulinoterapia?",
            "options": [
                "M\u00faltiplas doses di\u00e1rias (caneta/seringa)",
                "Bomba de infus\u00e3o de insulina (RII)"
            ]
        },
        {
            "typeQuestion": "CheckboxQuestion",
            "question": "7. Quais tipos de insulina voc\u00ea utiliza atualmente?",
            "options": [
                "Insulina ultra-r\u00e1pida",
                "Insulina r\u00e1pida",
                "Insulina basal (NPH)",
                "Insulina an\u00e1loga de longa dura\u00e7\u00e3o",
                "Outras"
            ]
        },
        {
            "typeQuestion": "SingleSelectionQuestion",
            "question": "8. Voc\u00ea realiza a contagem de carboidratos para as refei\u00e7\u00f5es?",
            "options": [
                "Sim, sempre",
                "Sim, \u00e0s vezes",
                "N\u00e3o realizo"
            ]
        },
        {
            "typeQuestion": "TextQuestion",
            "question": "9. Qual a sua meta glic\u00eamica alvo definida pela equipe m\u00e9dica (mg/dL)?",
            "options": null
        },
        {
            "typeQuestion": "SingleSelectionQuestion",
            "question": "10. Com que frequ\u00eancia voc\u00ea apresenta epis\u00f3dios de hipoglicemia (menor que 70 mg/dL) por semana?",
            "options": [
                "Nunca",
                "1 a 2 vezes",
                "3 a 5 vezes",
                "Mais de 5 vezes"
            ]
        },
        {
            "typeQuestion": "SingleSelectionQuestion",
            "question": "11. Voc\u00ea costuma sentir os sintomas f\u00edsicos da hipoglicemia quando ela ocorre?",
            "options": [
                "Sim, sinto claramente",
                "Sinto apenas se estiver muito baixa",
                "N\u00e3o sinto mais (hipoglicemia assintom\u00e1tica)"
            ]
        },
        {
            "typeQuestion": "SingleSelectionQuestion",
            "question": "12. J\u00e1 apresentou algum epis\u00f3dio de hipoglicemia grave (com perda de consci\u00eancia ou necessidade de ajuda de terceiros) no \u00faltimo ano?",
            "options": [
                "Sim",
                "N\u00e3o"
            ]
        },
        {
            "typeQuestion": "IntegerQuestion",
            "question": "13. Quantas vezes voc\u00ea j\u00e1 foi hospitalizado por Cetoacidose Diab\u00e9tica (CAD)?",
            "options": null
        },
        {
            "typeQuestion": "SingleSelectionQuestion",
            "question": "14. Voc\u00ea possui o h\u00e1bito de rotacionar os locais de aplica\u00e7\u00e3o de insulina?",
            "options": [
                "Sim, sempre",
                "\u00c0s vezes",
                "Raramente"
            ]
        },
        {
            "typeQuestion": "SingleSelectionQuestion",
            "question": "15. Voc\u00ea apresenta \u00e1reas de lipodistrofia (n\u00f3dulos ou endurecimentos nos locais de aplica\u00e7\u00e3o)?",
            "options": [
                "Sim",
                "N\u00e3o",
                "N\u00e3o sei identificar"
            ]
        },
        {
            "typeQuestion": "SingleSelectionQuestion",
            "question": "16. Com que frequ\u00eancia voc\u00ea pratica atividades f\u00edsicas?",
            "options": [
                "Sedent\u00e1rio",
                "1 a 2 vezes por semana",
                "3 a 5 vezes por semana",
                "Diariamente"
            ]
        },
        {
            "typeQuestion": "TextQuestion",
            "question": "17. Voc\u00ea ajusta a dose de insulina ou o consumo de carboidratos antes de se exercitar?",
            "options": null
        },
        {
            "typeQuestion": "TextQuestion",
            "question": "18. Voc\u00ea possui outras condi\u00e7\u00f5es autoimunes associadas (ex: Tireoidite de Hashimoto, Doen\u00e7a Cel\u00edaca)?",
            "options": null
        },
        {
            "typeQuestion": "SingleSelectionQuestion",
            "question": "19. Realiza o exame de fundo de olho (mapeamento de retina) anualmente?",
            "options": [
                "Sim",
                "N\u00e3o"
            ]
        },
        {
            "typeQuestion": "SingleSelectionQuestion",
            "question": "20. J\u00e1 realizou exames para avaliar a fun\u00e7\u00e3o renal (microalbumin\u00faria/creatinina) nos \u00faltimos 12 meses?",
            "options": [
                "Sim",
                "N\u00e3o"
            ]
        },
        {
            "typeQuestion": "TextQuestion",
            "question": "21. Como voc\u00ea avalia o impacto do diabetes na sua sa\u00fade mental e rotina di\u00e1ria?",
            "options": null
        }
    ],
